{
  "schema": "tau.dag_contract.v1",
  "dag_id": "gs001-extraction-repair-v1",
  "goal": {
    "goal_id": "PDF-EXTRACTION-GS001-TAU-V1",
    "goal_version": 1,
    "goal_hash": "sha256:ca56881acd36f5fdffffafc2a2ee73bbfd806df820f2fe0bd50ec52e794308ca"
  },
  "target": {
    "repo": "grahama1970/pdf_oxide",
    "target": "GS001 golden slice: NIST SP 800-53r5 page index 27 (printed PAGE 1)",
    "allowed_paths": [
      "python/pdf_oxide/extract_for_pdflab.py",
      "python/pdf_oxide/presets/*",
      "python/pdf_oxide/presets/document_families/*",
      "python/pdf_oxide/page_review_eval/*",
      "src/extractors/block_classifier.rs",
      "tests/test_nist_page_28_regression.py"
    ]
  },
  "entry_node": "extract-gs001",
  "terminal_nodes": [
    "closure-publisher",
    "human"
  ],
  "limits": {
    "resume": true,
    "default_timeout_seconds": 600,
    "max_total_attempts": 12
  },
  "nodes": [
    {
      "id": "extract-gs001",
      "agent": "coder",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "actual_elements.json",
        "page render PNG"
      ]
    },
    {
      "id": "compare-contract",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "comparison.json (pdf-lab.comparison.v2 defect vector)"
      ]
    },
    {
      "id": "second-pass-review",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "human_triage_queue.json",
        "agent_resolved_findings.json",
        "pdf-lab-second-pass-backlog.json",
        "scillm_preflight.json"
      ]
    },
    {
      "id": "owner-router",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "owner routing per pdf_lab.extraction_discrepancy.v1 owner_layer"
      ]
    },
    {
      "id": "ticket-projector",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "gs001-ticket-projection.json (dry run, defect_key dedup)"
      ]
    },
    {
      "id": "apply-gate",
      "agent": "human",
      "executor": "human",
      "required_evidence": [
        "tau.human_approval_packet.v1 for any live GitHub mutation"
      ]
    },
    {
      "id": "bounded-fixer",
      "agent": "coder",
      "executor": "local",
      "max_attempts": 2,
      "required_evidence": [
        "repair_receipt.json (pdf_lab.repair_transaction_receipt.v1)",
        "attempt branch commit sha or rollback record"
      ]
    },
    {
      "id": "regression-referee",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "reviewer": {
        "reviews_node": "bounded-fixer"
      },
      "required_evidence": [
        "regression_verdict.json (pdf_lab.regression_verdict.v1, PASS requires targeted class strictly decreased)"
      ]
    },
    {
      "id": "rerun-extraction",
      "agent": "coder",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "post-fix actual_elements.json + comparison.json"
      ]
    },
    {
      "id": "closure-audit",
      "agent": "reviewer",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "gs001-closure-report.json via `tau workflows run gs001-closure-audit`"
      ]
    },
    {
      "id": "closure-publisher",
      "agent": "releaser",
      "executor": "local",
      "max_attempts": 1,
      "required_evidence": [
        "closure report + terminal ledger + goal-hash continuity"
      ]
    },
    {
      "id": "human",
      "agent": "human",
      "executor": "human"
    }
  ],
  "edges": [
    {
      "from": "extract-gs001",
      "to": "compare-contract"
    },
    {
      "from": "compare-contract",
      "to": "closure-audit",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "comparison_passed",
        "value": true
      }
    },
    {
      "from": "compare-contract",
      "to": "second-pass-review",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "comparison_passed",
        "value": false
      }
    },
    {
      "from": "second-pass-review",
      "to": "owner-router"
    },
    {
      "from": "owner-router",
      "to": "human",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "owner_layer",
        "value": "human_contract_ambiguity"
      }
    },
    {
      "from": "owner-router",
      "to": "ticket-projector",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "neq",
        "field": "owner_layer",
        "value": "human_contract_ambiguity"
      }
    },
    {
      "from": "ticket-projector",
      "to": "apply-gate"
    },
    {
      "from": "apply-gate",
      "to": "bounded-fixer"
    },
    {
      "from": "bounded-fixer",
      "to": "regression-referee"
    },
    {
      "from": "regression-referee",
      "to": "rerun-extraction",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "verdict",
        "value": "PASS"
      }
    },
    {
      "from": "regression-referee",
      "to": "bounded-fixer",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "verdict",
        "value": "FAIL"
      }
    },
    {
      "from": "regression-referee",
      "to": "human",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "attempts_exhausted",
        "value": true
      }
    },
    {
      "from": "rerun-extraction",
      "to": "closure-audit"
    },
    {
      "from": "closure-audit",
      "to": "closure-publisher",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "closed",
        "value": true
      }
    },
    {
      "from": "closure-audit",
      "to": "human",
      "condition": {
        "schema": "tau.route_condition.v1",
        "op": "eq",
        "field": "closed",
        "value": false
      }
    }
  ],
  "required_evidence": [
    "goal-lock receipt (pdf_lab.goal_lock.v1) with resolved pins",
    "expected-contract lock receipt (pdf_lab.expected_contract_lock.v1, 11 rows)",
    "source PDF sha256 match",
    "scillm auth preflight (fail closed)",
    "repair transaction receipts with real rollback",
    "regression verdict PASS",
    "gs001-closure-report.json closed:true",
    "human acceptance packet"
  ],
  "fail_closed_on": [
    "goal_hash_mismatch",
    "target_changed",
    "unexpected_node",
    "unexpected_edge",
    "missing_required_evidence",
    "max_attempts_exceeded",
    "malformed_handoff",
    "patch_path_violation",
    "expected_contract_not_locked",
    "anti_overfit_inspection_failed"
  ]
}
