{
  "name": "pdf-lab-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3012",
    "dev:api": "tsx server/index.ts",
    "dev:all": "concurrently \"vite --host 127.0.0.1 --port 3012\" \"tsx server/index.ts\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 3012",
    "preview:all": "PDF_LAB_API_PORT=3012 tsx server/index.ts",
    "start": "PDF_LAB_API_PORT=3012 tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.4.394",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
