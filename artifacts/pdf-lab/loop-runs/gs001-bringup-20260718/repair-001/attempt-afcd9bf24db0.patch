+/// True when the text carries a running page marker, e.g. "PAGE 12",
+/// "p. 12", or a bare trailing page number.
+///
+/// Positional/typographic only: no document-specific phrase, no page-index
+/// condition, no control identifier. Used to keep running footers that also
+/// restate a chapter or section name from being treated as body content.
+fn has_page_marker(text: &str) -> bool {
+    let trimmed = text.trim();
+    let lower = trimmed.to_lowercase();
+    // "page 12" / "p. 12" / "pg 12" anywhere in a short chrome line
+    let mut words = lower.split_whitespace().peekable();
+    while let Some(w) = words.next() {
+        let w = w.trim_matches(|c: char| !c.is_alphanumeric());
+        if matches!(w, "page" | "pg" | "p") {
+            if let Some(next) = words.peek() {
+                if next.trim_matches(|c: char| !c.is_ascii_digit()).parse::<u32>().is_ok() {
+                    return true;
+                }
+            }
+        }
+    }
+    // bare trailing number ("... 12")
+    trimmed
+        .rsplit_whitespace()
+        .next()
+        .map(|last| last.trim_matches(|c: char| !c.is_ascii_digit()).parse::<u32>().is_ok())
+        .unwrap_or(false)
+}
