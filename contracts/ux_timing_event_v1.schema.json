{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdf-oxide.local/contracts/ux_timing_event_v1.schema.json",
  "title": "PDF Oxide UX timing event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_id",
    "workload_id",
    "fixture_sha256",
    "ui_commit",
    "item_id",
    "action",
    "started_at",
    "completed_at",
    "duration_ms"
  ],
  "properties": {
    "schema": { "const": "pdf_oxide.ux_timing_event.v1" },
    "event_id": { "$ref": "#/$defs/sha256" },
    "workload_id": { "type": "string", "minLength": 1 },
    "fixture_sha256": { "$ref": "#/$defs/sha256" },
    "ui_commit": { "type": "string", "minLength": 1 },
    "item_id": { "type": "string", "minLength": 1 },
    "action": { "enum": ["accept", "defer", "correct_type", "correct_bounds"] },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "number", "minimum": 0 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
