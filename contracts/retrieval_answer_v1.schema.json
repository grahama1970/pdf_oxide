{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdf-oxide.local/contracts/retrieval_answer_v1.schema.json",
  "title": "PDF Oxide retrieval answer v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "answer",
    "pdf_sha256",
    "section_id",
    "section_path",
    "vector_provenance",
    "evidence_groups"
  ],
  "properties": {
    "schema": { "const": "pdf_oxide.retrieval_answer.v1" },
    "answer": { "type": "string", "minLength": 1 },
    "pdf_sha256": { "$ref": "#/$defs/sha256" },
    "section_id": { "type": "string", "minLength": 1 },
    "section_path": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "vector_provenance": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "model_sha256", "preprocessing_sha256", "point_ids"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "model_sha256": { "$ref": "#/$defs/sha256" },
            "preprocessing_sha256": { "$ref": "#/$defs/sha256" },
            "point_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "evidence_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["page", "page_image", "evidence"],
        "properties": {
          "page": { "type": "integer", "minimum": 0 },
          "page_image": {
            "type": "object",
            "additionalProperties": false,
            "required": ["href", "sha256", "byte_sha256", "verified"],
            "properties": {
              "href": { "type": "string", "minLength": 1 },
              "sha256": { "$ref": "#/$defs/sha256" },
              "byte_sha256": { "$ref": "#/$defs/sha256" },
              "verified": { "const": true },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            }
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "overlay_number",
                "element_id",
                "type",
                "bbox",
                "section_id",
                "section_path"
              ],
              "properties": {
                "overlay_number": { "type": "integer", "minimum": 1 },
                "element_id": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "minLength": 1 },
                "bbox": {
                  "type": "array",
                  "prefixItems": [
                    { "type": "number", "minimum": 0, "maximum": 1 },
                    { "type": "number", "minimum": 0, "maximum": 1 },
                    { "type": "number", "minimum": 0, "maximum": 1 },
                    { "type": "number", "minimum": 0, "maximum": 1 }
                  ],
                  "items": false,
                  "minItems": 4,
                  "maxItems": 4
                },
                "section_id": { "type": "string", "minLength": 1 },
                "section_path": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "text": { "type": "string" },
                "table_cells": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["answers"] },
      { "required": ["alternatives"] },
      { "required": ["ranked_answers"] }
    ]
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
